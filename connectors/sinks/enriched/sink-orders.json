{
  "name": "sink-orders",
  "config": {
    "_comment": "ORDERS is enriched by orders-domain Kafka Streams app (joins ORDERS+CUSTOMERS+PRODUCTS). Reads enriched topic.",

    "connector.class": "com.mongodb.kafka.connect.MongoSinkConnector",
    "topics": "enriched.orders",
    "connection.uri": "mongodb://root:root@mongodb:27017",
    "database": "poc",
    "collection": "orders",

    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",

    "document.id.strategy": "com.mongodb.kafka.connect.sink.processor.id.strategy.PartialValueStrategy",
    "document.id.strategy.partial.value.projection.list": "orderId",
    "document.id.strategy.partial.value.projection.type": "AllowList",
    "writemodel.strategy": "com.mongodb.kafka.connect.sink.writemodel.strategy.ReplaceOneBusinessKeyStrategy"
  }
}
