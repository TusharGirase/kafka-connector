{
  "name": "sink-hr-profiles",
  "config": {
    "_comment": "HR profile is enriched by hr-domain Kafka Streams app (joins EMPLOYEES+DEPARTMENTS). Reads enriched topic.",

    "connector.class": "com.mongodb.kafka.connect.MongoSinkConnector",
    "topics": "enriched.employee-profiles",
    "connection.uri": "mongodb://root:root@mongodb:27017",
    "database": "poc",
    "collection": "employeeProfiles",

    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",

    "document.id.strategy": "com.mongodb.kafka.connect.sink.processor.id.strategy.PartialValueStrategy",
    "document.id.strategy.partial.value.projection.list": "employeeId",
    "document.id.strategy.partial.value.projection.type": "AllowList",
    "writemodel.strategy": "com.mongodb.kafka.connect.sink.writemodel.strategy.ReplaceOneBusinessKeyStrategy"
  }
}
